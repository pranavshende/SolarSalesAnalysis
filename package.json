{
  "name": "solar-intelligence-platform",
  "version": "1.0.0",
  "description": "Solar Intelligence & Sales Optimization Platform",
  "scripts": {
    "frontend": "npm run dev --prefix frontend",
    "backend": "npm run dev --prefix backend",
